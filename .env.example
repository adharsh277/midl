# Bitcoin Network Configuration  (Testnet4 = current Bitcoin testnet)
NEXT_PUBLIC_BITCOIN_NETWORK=testnet4
NEXT_PUBLIC_MEMPOOL_API=https://mempool.space/testnet4/api

# Xverse Wallet (no configuration needed - browser-based)
# Xverse is detected automatically via window.xverseProviders

# Application Configuration
NEXT_PUBLIC_APP_TITLE=Bitcoin Smart Escrow
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional: For advanced features
# MIDL_API_KEY=your_midl_api_key_here

# Midl RPC + Contract (Client-side configuration)
NEXT_PUBLIC_MIDL_RPC_URL=https://rpc.staging.midl.xyz
NEXT_PUBLIC_MIDL_CHAIN_ID=15001
NEXT_PUBLIC_MIDL_CHAIN_NAME=midl-staging
NEXT_PUBLIC_MIDL_NATIVE_CURRENCY_NAME=BTC
NEXT_PUBLIC_MIDL_NATIVE_CURRENCY_SYMBOL=BTC
NEXT_PUBLIC_MIDL_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Client-side explorer for tx hash links
NEXT_PUBLIC_MIDL_EXPLORER=https://blockscout.staging.midl.xyz

# NOTE: Client-side wallet signing is now used.
# No backend private keys needed.
